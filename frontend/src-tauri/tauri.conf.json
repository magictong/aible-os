{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Aible OS",
  "version": "0.1.0",
  "identifier": "com.aibleos.app",
  "build": {
    "frontendDist": "web",
    "devUrl": "http://localhost:8765",
    "beforeBuildCommand": "",
    "beforeDevCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "Aible OS",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "apps",
      "runtime",
      "venv"
    ],
    "externalBin": [
      "binaries/start-backend"
    ],
    "macOS": {
      "signingIdentity": "-"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
